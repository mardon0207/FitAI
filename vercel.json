{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @fit/web build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "pnpm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ecofit-api.vercel.app/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://ecofit-api.vercel.app/health"
    }
  ]
}
