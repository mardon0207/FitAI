ENV=dev
DEBUG=true

# PostgreSQL - local docker defaults
DATABASE_URL=postgresql+asyncpg://fit:fit@localhost:5432/fit
DATABASE_URL_SYNC=postgresql+psycopg2://fit:fit@localhost:5432/fit
DATABASE_URL_UNPOOLED=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Auth
JWT_SECRET=change-me-in-production-please-very-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# USDA API (optional - DEMO_KEY works but is rate-limited)
USDA_API_KEY=

# OpenFoodFacts
OPENFOODFACTS_USER_AGENT=FitAI/0.1 (family-use)

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://ecofit-cph1.vercel.app
CORS_ORIGIN_REGEX=^https://([a-z0-9-]+\\.)?vercel\\.app$
